{
  "name": "atif-visualizer",
  "displayName": "ATIF Preview",
  "description": "Visualize Agent Trajectory Interchange Format (ATIF) files",
  "version": "0.7.1",
  "publisher": "waldek",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldekmastykarz/vsc-atifviz.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "atifPreview",
        "displayName": "ATIF Trajectory Preview",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "atif-visualizer.preview",
        "title": "ATIF: Preview Trajectory",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "atif-visualizer.showSource",
        "title": "ATIF: Show Source",
        "icon": "$(file-code)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == json && activeCustomEditorId != atifPreview",
          "command": "atif-visualizer.preview",
          "group": "navigation"
        },
        {
          "when": "activeCustomEditorId == atifPreview",
          "command": "atif-visualizer.showSource",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}

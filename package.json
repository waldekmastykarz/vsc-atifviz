{
  "name": "atif-visualizer",
  "displayName": "ATIF Trajectory Visualizer",
  "description": "Visualize Agent Trajectory Interchange Format (ATIF) files",
  "version": "0.4.1",
  "publisher": "waldek",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldekmastykarz/vsc-atifviz.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atif-visualizer.preview",
        "title": "ATIF: Preview Trajectory",
        "icon": "$(type-hierarchy-sub)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == json",
          "command": "atif-visualizer.preview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
